            "author_description": "Home Chef & Food Enthusiast"
          }
        },
        "quote_tP73V7": {
          "type": "quote",
          "settings": {
            "star_rating": 4,
            "review_content": "<p>\"I love that I can find everything from everyday essentials to gourmet ingredients here. Cooking at home has never been this fun and easy!\"</p>",
            "author_name": "Olivia S.",
            "author_description": "Aspiring Chef"
          }
        },
        "quote_wyEmEA": {
          "type": "quote",
          "settings": {
            "star_rating": 4,
            "review_content": "<p>\"From pantry staples to premium cookware, this store has everything I need. Shopping here makes meal prep so much easier!\"</p>",
            "author_name": "Daniel M.",
            "author_description": "Homemaker"
          }
        },
        "quote_ELj4NN": {
          "type": "quote",
          "settings": {
            "star_rating": 5,
            "review_content": "<p>\"I love how quickly my orders arrive, and the ingredients are always fresh. The kitchen tools I bought are also top-notch!\"</p>",
