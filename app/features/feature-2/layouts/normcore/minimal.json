        },
        "quote_kzJJUW": {
          "type": "quote",
          "settings": {
            "star_rating": 4,
            "review_content": "<p>\"I've been shopping here for months, and the freshness of the produce and meats is unmatched. Plus, their kitchenware selection is super handy!\"</p>",
