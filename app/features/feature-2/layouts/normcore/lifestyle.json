    "testimonials_TDkFDP": {
      "type": "testimonials",
      "blocks": {
        "testimonial_m4VtLw": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 5,
            "review_content": "<p>NORMCORE™ Fundamental has completely transformed my wardrobe. The quality is unmatched, and the designs are timeless. As someone who values simplicity and functionality, this brand truly resonates with my lifestyle. Highly recommend to anyone looking for essentials that stand the test of time!</p>",
            "author_name": "Alex Tran",
            "author_description": "A passionate minimalist and coffee enthusiast"
          }
        },
        "testimonial_737RNg": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 4,
            "review_content": "<p>I love how versatile and comfortable the pieces are. They fit seamlessly into my daily routine, whether I'm running errands or heading to yoga class. NORMCORE™ Fundamental is my go-to for stylish yet practical clothing.</p>",
            "author_name": "Sarah N.",
            "author_description": "A busy mom and yoga enthusiast"
          }
        },
        "testimonial_hqrRUn": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 5,
            "review_content": "<p>The attention to detail and craftsmanship is incredible. Every piece feels like it was made just for me. NORMCORE™ Fundamental is redefining what it means to have a wardrobe of essential</p>",
            "author_name": "Michael Le",
            "author_description": "A tech entrepreneur and sneaker collector"
          }
        },
        "testimonial_K3wr8m": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 5,
            "review_content": "<p>I’ve never felt more confident in my everyday outfits. The clean lines and neutral tones make it so easy to mix and match. NORMCORE™ Fundamental is a game-changer for anyone who loves effortless style.</p>",
            "author_name": "Emily P.",
            "author_description": "A freelance graphic designer and coffee shop hopper."
          }
        },
        "testimonial_8Mb4Kk": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 5,
            "review_content": "<p>The durability of these clothes is amazing. I’ve worn them hiking, to the gym, and even to casual dinners. They hold up so well and still look great. NORMCORE™ Fundamental is the real deal!</p>",
            "author_name": "Rosie",
            "author_description": "Artist - A Creative Visionary"
          }
        },
        "testimonial_R3JBpE": {
          "type": "testimonial",
          "settings": {
            "icon_image": "",
            "rating": 5,
            "review_content": "<p>As a student, I need interrior that are affordable, durable, and stylish. NORMCORE™ Fundamental checks all the boxes.</p>",
            "author_name": "Kevin",
            "author_description": "Aspiring Professional & Lifelong Learner"
          }
        }
      },
      "block_order": [
        "testimonial_m4VtLw",
