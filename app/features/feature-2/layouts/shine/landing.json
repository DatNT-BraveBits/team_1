        "tab_DC8Bxf": {
          "type": "tab",
          "settings": {
            "heading": "Cleanse Your Skin",
            "description": "<p>Take a warm shower or bath and gently cleanse your body using a mild soap or body wash. Pat your skin dry with a soft towel, leaving it slightly damp.</p>"
          }
        },
        "tab_CiMmfC": {
          "type": "tab",
          "settings": {
            "heading": "Exfoliate Gently",
            "description": "<p>Use a mild exfoliant to remove dead skin cells and unclog pores. Over-exfoliating can lead to irritation, so limit this step to once or twice a week.</p>"
          }
        },
        "tab_EHNjm4": {
          "type": "tab",
          "settings": {
            "heading": "Apply Face Mask",
            "description": "<p>Using clean fingers or a brush, apply the mask evenly over your face, avoiding the eye and lip areas.</p>"
          }
        },
        "tab_9YP3n6": {
          "type": "tab",
          "settings": {
            "heading": "Massage and Absorb",
            "description": "<p>Apply your moisturizer in upward strokes, gently massaging it into your skin to boost circulation and absorption.</p>"
          }
        }
      },
