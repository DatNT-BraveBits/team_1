    "spotlight_quotes": {
      "type": "spotlight-quotes",
      "blocks": {
        "quocte_nVVLeb": {
          "type": "quocte",
          "settings": {
            "avatar_width": 60,
            "avatar_width_mobile": 40,
            "star": 3,
            "quote_label": "<h4>As someone who's always on the lookout for the latest in skincare, I've been incredibly impressed with the selection at this beauty store. Their range of organic and cruelty-free products is exactly what I've been searching for.</h4>",
            "author": "Sophia, Age 28"
          }
        },
        "quocte_JHHFzT": {
          "type": "quocte",
          "settings": {
            "avatar_width": 60,
            "avatar_width_mobile": 40,
            "star": 3,
            "quote_label": "<h4>I never paid much attention to skincare or grooming products until I visited this store. The staff was super helpful, walking me through various options for my skin type. I've started using their recommended face wash and moisturizer, and I've noticed a significant improvement in my skin's texture.</h4>",
            "author": "Michael, Age 35"
          }
        },
        "quocte_fpTGex": {
          "type": "quocte",
          "settings": {
            "avatar_width": 60,
            "avatar_width_mobile": 40,
            "star": 3,
            "quote_label": "<h4>I've been a loyal customer of this beauty store for years. What keeps me coming back is their impeccable customer service and the high-quality, diverse range of products they offer. Whether it's makeup, skincare, or haircare, I've always found what I need. </h4>",
            "author": "Ava, Age 18"
          }
        }
      },
      "block_order": [
        "quocte_nVVLeb",
