          "settings": {
            "name": "Patricia J. Adams",
            "job_title": "Professional yoga trainner",
            "text": "\u201cI thought these would be too warm, but I recently wore them on a road trip to the desert and surprisingly they kept me warm when it was cool and cool when it was warm.\u201d"
