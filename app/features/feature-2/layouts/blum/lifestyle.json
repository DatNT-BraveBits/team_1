          "type": "testimonial",
          "settings": {
            "name": "Jessie",
            "job_title": "Fashion trend-setter",
            "text": "\u201cVery satisfied. I ordered a 2 and it fit perfectly. No need to size up or size down. The pants are very cute and stretchy. Fit great over my boots and have nice shaping on my leg.\u201d"
          }
        },
        "ab9f5b0c-ede0-4d38-8ea8-cb3156686ae7": {
