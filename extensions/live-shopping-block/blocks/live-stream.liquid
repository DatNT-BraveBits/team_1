{% comment %}
  Live Shopping Block — Feature 5
  Displays a Mux livestream with product panel for customers
{% endcomment %}

<div id="live-shopping-app" data-session-id="{{ block.settings.session_id }}" data-shop="{{ shop.permanent_domain }}">
  <div class="ls-container">
    <!-- Video Player -->
    <div class="ls-player">
      <div id="ls-video-wrapper">
        <div class="ls-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <p>Stream starting soon...</p>
        </div>
        <video id="ls-video" playsinline autoplay muted></video>
      </div>
      <div id="ls-live-badge" class="ls-badge ls-badge--hidden">LIVE</div>
    </div>

    <!-- Pinned Product -->
    <div id="ls-pinned" class="ls-pinned ls-hidden"></div>

    <!-- Product Grid -->
    <div id="ls-products" class="ls-products"></div>
  </div>
</div>

{{ 'live-stream.css' | asset_url | stylesheet_tag }}
<script src="{{ 'live-stream.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Live Shopping",
  "settings": [
    {
      "type": "text",
      "id": "session_id",
      "label": "Livestream Session ID",
      "info": "Paste the session ID from your Live Shopping dashboard"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Live Shopping"
    },
    {
      "type": "range",
      "id": "refresh_interval",
      "label": "Refresh interval (seconds)",
      "min": 5,
      "max": 30,
      "step": 5,
      "default": 10
    }
  ]
}
{% endschema %}
